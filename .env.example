# Database connection for local Python scripts
DB_HOST=localhost
DB_PORT=2402
DB_NAME=law_db
DB_USER=root
DB_PASSWORD=@12345@

# Vector database
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION=vbpl_embed

# Embedding model
HF_TOKEN=hf_xxx
EMBEDDING_MODEL=truro7/vn-law-embedding
EMBEDDING_DEVICE=auto
EMBED_BATCH_SIZE=128
GPU_EMBED_BATCH_SIZE=64

# FPT AI generation API
FPT_API_KEY=fpt_xxx
FPT_BASE_URL=https://mkp-api.fptcloud.com/v1
FPT_MODEL=Llama-3.3-70B-Instruct
GENERATION_TOP_K=40
GENERATION_PRESENCE_PENALTY=0
GENERATION_FREQUENCY_PENALTY=0

# Rerank model
RERANK_MODEL=AITeamVN/Vietnamese_Reranker

# Classify model
CLASSIFY_MODEL=MoritzLaurer/mDeBERTa-v3-base-xnli-multilingual-nli-2mil7

# Crawl source
VBPL_GATEWAY_BASE_URL=https://vbpl-bientap-gateway.moj.gov.vn

# Web
VITE_CHAT_API_URL=http://localhost:8000/chat
