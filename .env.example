# Database connection for local Python scripts
DB_HOST=localhost
DB_PORT=2402
DB_NAME=law_db
DB_USER=root
DB_PASSWORD=@12345@

# Vector database
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION=vbpl_embed

# Embedding model
HF_TOKEN=hf_xxx
EMBEDDING_MODEL=truro7/vn-law-embedding
EMBEDDING_DEVICE=auto
EMBED_BATCH_SIZE=128

# GGUF generation model
GENERATION_MODEL_REPO=vinai/PhoGPT-4B-Chat-gguf
GENERATION_MODEL_FILENAME=PhoGPT-4B-Chat-Q4_K_M.gguf
GENERATION_CONTEXT_LENGTH=2048
GENERATION_GPU_LAYERS=-1

# Crawl source
VBPL_GATEWAY_BASE_URL=https://vbpl-bientap-gateway.moj.gov.vn

